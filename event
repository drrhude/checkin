
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>CVC Spine & Sport — Find Your Care</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet">
<script src="https://apis.google.com/js/api.js" async defer onload="gapiLoaded()"></script>
<script src="https://accounts.google.com/gsi/client" async defer onload="gisLoaded()"></script>
<style>
:root{
  --sage:#5a8f6e;--sage-dk:#2f5c43;--sage-lt:#b8d8c4;--sage-xl:#eaf4ee;
  --ink:#182820;--ink-md:#3b4e41;--ink-sm:#677a6e;
  --cream:#f6faf7;--white:#ffffff;
  --border:#c8dcd0;--border-lt:#e2ede7;
  --gold:#c08a32;--gold-lt:#fdf3e3;--gold-dk:#8a6020;
  --red:#c0392b;--red-lt:#fdf0ee;
  --blue:#2563a8;--blue-lt:#eaf1fc;
  --purple:#6a4a8f;--purple-lt:#f0eaf7;
  --teal:#2a8a8e;--teal-lt:#e5f4f5;
  --radius:14px;--radius-sm:9px;
  --shadow:0 2px 10px rgba(0,0,0,.06);
  --shadow-md:0 6px 24px rgba(0,0,0,.1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{font-size:16px;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--ink);line-height:1.5;min-height:100vh;-webkit-tap-highlight-color:transparent;}

/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:500;display:none;align-items:center;justify-content:center;padding:20px;}
.modal-overlay.open{display:flex;}
.modal{background:var(--white);border-radius:var(--radius);padding:28px;width:100%;max-width:480px;max-height:90vh;overflow-y:auto;box-shadow:var(--shadow-md);}
.modal h2{font-family:'DM Serif Display',serif;font-size:1.35rem;margin-bottom:16px;}
.modal .close-btn{float:right;background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--ink-sm);margin-top:-4px;}

/* TOP BAR */
.topbar{background:var(--white);border-bottom:2px solid var(--sage-lt);padding:12px 20px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;box-shadow:var(--shadow);}
.brand{font-family:'DM Serif Display',serif;font-size:1.15rem;color:var(--sage-dk);line-height:1.1;}
.brand em{color:var(--sage);font-style:italic;}
.brand-sub{font-size:.62rem;letter-spacing:.13em;text-transform:uppercase;color:var(--ink-sm);margin-top:2px;font-weight:500;}
.topbar-right{display:flex;align-items:center;gap:10px;}
.lang-toggle{display:flex;background:var(--sage-xl);border:1.5px solid var(--sage-lt);border-radius:100px;overflow:hidden;}
.lang-btn{padding:5px 14px;font-size:.78rem;font-weight:700;cursor:pointer;background:none;border:none;font-family:'DM Sans',sans-serif;color:var(--ink-sm);transition:all .15s;}
.lang-btn.active{background:var(--sage-dk);color:white;}
.settings-btn{background:none;border:1.5px solid var(--border);border-radius:8px;padding:6px 10px;font-size:.8rem;cursor:pointer;color:var(--ink-sm);font-family:'DM Sans',sans-serif;}
.settings-btn:hover{border-color:var(--sage);color:var(--sage-dk);}

/* PROGRESS */
.progress-strip{background:var(--white);border-bottom:1px solid var(--border-lt);padding:10px 20px 12px;}
.psteps{display:flex;gap:4px;margin-bottom:5px;}
.ps{flex:1;height:4px;background:var(--border-lt);border-radius:2px;transition:background .3s;}
.ps.done{background:var(--sage-dk);}
.ps.active{background:var(--sage);}
.phase-lbl{font-size:.65rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--sage-dk);}

/* LAYOUT */
.app{max-width:660px;margin:0 auto;padding:0 0 120px;}
.screen{display:none;}
.screen.active{display:block;animation:fadeUp .3s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.inner{padding:24px 18px 18px;}

/* TYPO */
h1{font-family:'DM Serif Display',serif;font-size:clamp(1.6rem,4.5vw,2.2rem);color:var(--ink);margin-bottom:8px;line-height:1.2;}
h2{font-family:'DM Serif Display',serif;font-size:1.25rem;color:var(--ink);margin-bottom:6px;}
.sec-desc{color:var(--ink-sm);font-size:.92rem;margin-bottom:20px;line-height:1.65;}
.step-num{display:inline-block;background:var(--sage-dk);color:white;border-radius:100px;font-size:.72rem;font-weight:700;padding:2px 10px;margin-bottom:10px;letter-spacing:.06em;text-transform:uppercase;}

/* CARDS */
.card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);padding:20px;margin-bottom:14px;box-shadow:var(--shadow);}

/* CHOICE BUTTONS */
.choice-grid{display:flex;flex-direction:column;gap:10px;}
.choice-btn{
  display:flex;align-items:center;gap:14px;
  background:var(--white);border:2px solid var(--border);
  border-radius:var(--radius-sm);padding:15px 18px;
  cursor:pointer;transition:all .18s;text-align:left;
  font-family:'DM Sans',sans-serif;width:100%;
}
.choice-btn:hover{border-color:var(--sage);transform:translateX(3px);}
.choice-btn.sel{border-color:var(--sage-dk);background:var(--sage-xl);}
.choice-btn .ci{font-size:1.6rem;flex-shrink:0;width:38px;text-align:center;}
.choice-btn .ct{flex:1;}
.choice-btn .ct strong{display:block;font-size:.97rem;color:var(--ink);margin-bottom:2px;}
.choice-btn .ct span{font-size:.8rem;color:var(--ink-sm);line-height:1.4;}
.choice-btn .ck{width:22px;height:22px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;color:white;font-size:.75rem;transition:all .18s;}
.choice-btn.sel .ck{background:var(--sage-dk);border-color:var(--sage-dk);}

/* MULTI-SELECT note */
.multi-note{font-size:.78rem;color:var(--ink-sm);margin-bottom:12px;font-style:italic;}

/* FORM */
.fg{margin-bottom:16px;}
label.fl{font-size:.87rem;font-weight:600;color:var(--ink-md);display:block;margin-bottom:7px;}
input[type=text],input[type=tel],input[type=email]{
  width:100%;background:var(--cream);border:1.5px solid var(--border);
  border-radius:var(--radius-sm);padding:13px 15px;
  font-family:'DM Sans',sans-serif;font-size:1rem;color:var(--ink);
  outline:none;transition:border-color .2s,box-shadow .2s;-webkit-appearance:none;
}
input:focus{border-color:var(--sage);background:var(--white);box-shadow:0 0 0 3px rgba(90,143,110,.14);}
input::placeholder{color:#b0c4b8;}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:14px 28px;border-radius:var(--radius-sm);font-family:'DM Sans',sans-serif;font-size:.95rem;font-weight:700;cursor:pointer;border:none;transition:all .2s;white-space:nowrap;}
.btn-green{background:var(--sage-dk);color:white;box-shadow:0 3px 14px rgba(47,92,67,.28);}
.btn-green:hover{background:#1f4530;transform:translateY(-1px);}
.btn-ghost{background:var(--white);border:1.5px solid var(--border);color:var(--ink-md);}
.btn-ghost:hover{border-color:var(--sage);color:var(--sage-dk);}
.btn-gold{background:var(--gold);color:white;box-shadow:0 3px 14px rgba(192,138,50,.28);}
.btn-gold:hover{background:#9e7028;transform:translateY(-1px);}
.btn-full{width:100%;padding:17px;font-size:1rem;border-radius:12px;}
.btn-row{display:flex;justify-content:space-between;gap:10px;margin-top:22px;}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none;}

/* RESULT CARD */
.result-hero{text-align:center;padding:10px 0 22px;}
.result-icon{font-size:4rem;display:block;margin-bottom:10px;}
.result-badge{display:inline-block;padding:5px 18px;border-radius:100px;font-size:.78rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:14px;}
.result-badge.chiro{background:var(--sage-xl);color:var(--sage-dk);border:1px solid var(--sage-lt);}
.result-badge.sw{background:var(--gold-lt);color:var(--gold-dk);border:1px solid #e8c97a;}
.result-badge.np{background:var(--purple-lt);color:var(--purple);border:1px solid #d0bae0;}
.result-badge.rehab{background:var(--blue-lt);color:var(--blue);border:1px solid #b5cef0;}
.result-badge.multi{background:var(--teal-lt);color:var(--teal);border:1px solid #a8d4d6;}
.result-title{font-family:'DM Serif Display',serif;font-size:1.8rem;color:var(--ink);margin-bottom:8px;line-height:1.2;}
.result-why{background:var(--sage-xl);border:1px solid var(--sage-lt);border-radius:var(--radius-sm);padding:16px;margin:16px 0;font-size:.9rem;color:var(--ink-md);line-height:1.7;}
.result-why strong{color:var(--sage-dk);}

.also-consider{margin-top:14px;}
.also-consider-title{font-size:.72rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-sm);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.also-consider-title::after{content:'';flex:1;height:1px;background:var(--border-lt);}
.mini-cards{display:flex;flex-direction:column;gap:8px;}
.mini-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:13px 16px;display:flex;align-items:center;gap:12px;}
.mini-card .mi{font-size:1.4rem;flex-shrink:0;}
.mini-card .mt{flex:1;}
.mini-card .mt strong{display:block;font-size:.9rem;color:var(--ink);margin-bottom:2px;}
.mini-card .mt span{font-size:.78rem;color:var(--ink-sm);}

.offer-box{background:linear-gradient(135deg,var(--sage-dk),#1e4530);color:white;border-radius:var(--radius);padding:24px 20px;text-align:center;margin-top:18px;}
.offer-box .ob-label{font-size:.7rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;opacity:.8;margin-bottom:6px;}
.offer-box .ob-price{font-family:'DM Serif Display',serif;font-size:2.8rem;line-height:1;margin-bottom:4px;}
.offer-box .ob-name{font-size:1rem;font-weight:600;opacity:.9;margin-bottom:14px;}
.offer-box .ob-sub{font-size:.82rem;opacity:.72;margin-bottom:18px;line-height:1.6;}

/* SUCCESS */
.success-screen{min-height:60vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:44px 20px;}
.success-icon{width:90px;height:90px;border-radius:50%;background:var(--sage-xl);border:3px solid var(--sage-lt);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:2.4rem;}
.success-title{font-family:'DM Serif Display',serif;font-size:2rem;margin-bottom:10px;}
.success-sub{color:var(--ink-sm);font-size:.95rem;line-height:1.7;max-width:340px;}

/* DRIVE STATUS */
.drive-status{margin-top:12px;font-size:.82rem;padding:7px 16px;border-radius:100px;font-weight:600;display:inline-block;}
.drive-status.uploading{background:#eaf1fc;color:var(--blue);border:1px solid #b5cef0;}
.drive-status.success{background:var(--sage-xl);color:var(--sage-dk);border:1px solid var(--sage-lt);}
.drive-status.error{background:var(--red-lt);color:var(--red);border:1px solid #e8b4ad;}

@media(max-width:580px){
  .inner{padding:18px 14px;}
  .topbar{padding:11px 14px;}
}
</style>
</head>
<body>

<!-- SETTINGS MODAL -->
<div class="modal-overlay" id="settings-modal">
  <div class="modal">
    <button class="close-btn" onclick="closeSettings()">✕</button>
    <h2>⚙ Settings</h2>
    <p style="font-size:.83rem;color:var(--ink-sm);margin-bottom:16px;">Saved to this device only.</p>
    <div class="fg"><label class="fl">Booking Link (URL for $47 special)</label><input type="text" id="cfg-booking" placeholder="https://your-jane-app-link.com"></div>
    <div style="border-top:1px solid var(--border-lt);margin:16px 0;padding-top:16px;">
      <h2 style="font-size:1.05rem;margin-bottom:10px;">🔗 Google Sheets</h2>
      <p style="font-size:.8rem;color:var(--ink-sm);margin-bottom:12px;line-height:1.6;">Leads auto-save to your Google Sheet on submit.</p>
      <div class="fg"><label class="fl">Google OAuth Client ID</label><input type="text" id="cfg-goog-id" placeholder="xxxx.apps.googleusercontent.com"></div>
      <div class="fg"><label class="fl">Google Sheet ID</label><input type="text" id="cfg-sheet-id" placeholder="Sheet ID from the URL"></div>
      <div id="drive-auth-status" style="margin-bottom:12px;"></div>
      <button class="btn btn-ghost" id="drive-connect-btn" onclick="initDriveAuth()" style="width:100%;margin-bottom:12px;">Connect Google Account</button>
    </div>
    <button class="btn btn-green btn-full" onclick="saveSettings()">Save Settings</button>
  </div>
</div>

<div class="app">

  <!-- TOP BAR -->
  <div class="topbar">
    <div>
      <div class="brand">CVC Spine &amp; Sport <em>Care Finder</em></div>
      <div class="brand-sub">Colleyville, TX · (817) 420-7696</div>
    </div>
    <div class="topbar-right">
      <div class="lang-toggle">
        <button class="lang-btn active" id="lang-en" onclick="setLang('en')">EN</button>
        <button class="lang-btn" id="lang-es" onclick="setLang('es')">ES</button>
      </div>
      <button class="settings-btn" onclick="openSettings()">⚙</button>
    </div>
  </div>

  <!-- PROGRESS -->
  <div class="progress-strip" id="progress-strip">
    <div class="psteps">
      <div class="ps active" id="ps0"></div>
      <div class="ps" id="ps1"></div>
      <div class="ps" id="ps2"></div>
      <div class="ps" id="ps3"></div>
      <div class="ps" id="ps4"></div>
      <div class="ps" id="ps5"></div>
    </div>
    <div class="phase-lbl" id="phase-lbl" data-en="About You" data-es="Sobre Ti">About You</div>
  </div>

  <!-- ═══ SCREEN 0: WELCOME ═══ -->
  <div class="screen active" id="screen-0">
    <div class="inner">
      <div style="text-align:center;padding:8px 0 24px;">
        <div style="font-size:3rem;margin-bottom:12px;">🏥</div>
        <h1 data-en="What's Stopping You?" data-es="¿Qué Te Detiene?">What's Stopping You?</h1>
        <p class="sec-desc" data-en="Answer 5 quick questions and we'll tell you exactly which care is right for you — and why." data-es="Responde 5 preguntas rápidas y te diremos exactamente qué cuidado es el adecuado para ti.">Answer 5 quick questions and we'll tell you exactly which care is right for you — and why.</p>
        <p style="font-size:.8rem;color:var(--ink-sm);margin-top:-8px;" data-en="Takes less than 60 seconds." data-es="Menos de 60 segundos.">Takes less than 60 seconds.</p>
      </div>
      <button class="btn btn-green btn-full" onclick="goScreen(1)">
        <span data-en="Find My Care →" data-es="Encontrar Mi Cuidado →">Find My Care →</span>
      </button>
      <p style="text-align:center;font-size:.78rem;color:var(--ink-sm);margin-top:12px;" data-en="Colleyville Chiropractic | CVC Spine &amp; Sport · 1001 Glade Rd, Suite 120" data-es="Colleyville Chiropractic | CVC Spine &amp; Sport · 1001 Glade Rd, Suite 120">Colleyville Chiropractic | CVC Spine &amp; Sport · 1001 Glade Rd, Suite 120</p>
    </div>
  </div>

  <!-- ═══ SCREEN 1: Q1 — WHO ARE YOU ═══ -->
  <div class="screen" id="screen-1">
    <div class="inner">
      <div class="step-num" data-en="Question 1 of 5" data-es="Pregunta 1 de 5">Question 1 of 5</div>
      <h2 data-en="Which best describes you?" data-es="¿Cuál te describe mejor?">Which best describes you?</h2>
      <p class="sec-desc multi-note" data-en="Pick all that apply." data-es="Selecciona todo lo que aplique.">Pick all that apply.</p>
      <div class="choice-grid" id="q1-choices">
        <button class="choice-btn" onclick="toggleQ('q1','athlete')" data-val="athlete">
          <div class="ci">🏃</div>
          <div class="ct">
            <strong data-en="Athlete / Active Person" data-es="Atleta / Persona Activa">Athlete / Active Person</strong>
            <span data-en="Sport, training, performance — you move and want to stay moving" data-es="Deporte, entrenamiento — te mueves y quieres seguir moviéndote">Sport, training, performance — you move and want to stay moving</span>
          </div>
          <div class="ck">✓</div>
        </button>
        <button class="choice-btn" onclick="toggleQ('q1','worker')" data-val="worker">
          <div class="ci">🔧</div>
          <div class="ct">
            <strong data-en="Manual / Physical Worker" data-es="Trabajador Manual / Físico">Manual / Physical Worker</strong>
            <span data-en="Construction, trades, warehouse, labor — your body takes a beating daily" data-es="Construcción, oficios, almacén — tu cuerpo trabaja duro cada día">Construction, trades, warehouse, labor — your body takes a beating daily</span>
          </div>
          <div class="ck">✓</div>
        </button>
        <button class="choice-btn" onclick="toggleQ('q1','parent')" data-val="parent">
          <div class="ci">👨‍👩‍👧</div>
          <div class="ct">
            <strong data-en="Parent / Family" data-es="Padre/Madre / Familia">Parent / Family</strong>
            <span data-en="You carry kids, sit at desks, and forget about yourself — until it hurts" data-es="Cargas niños, te sientas en escritorios y te olvidas de ti mismo">You carry kids, sit at desks, and forget about yourself — until it hurts</span>
          </div>
          <div class="ck">✓</div>
        </button>
        <button class="choice-btn" onclick="toggleQ('q1','senior')" data-val="senior">
          <div class="ci">🧓</div>
          <div class="ct">
            <strong data-en="55+ / Senior" data-es="55+ / Mayor">55+ / Senior</strong>
            <span data-en="Staying mobile, managing chronic pain or nerve symptoms, or just feeling better" data-es="Mantenerse móvil, manejar dolor crónico o síntomas nerviosos">Staying mobile, managing chronic pain or nerve symptoms, or just feeling better</span>
          </div>
          <div class="ck">✓</div>
        </button>
        <button class="choice-btn" onclick="toggleQ('q1','office')" data-val="office">
          <div class="ci">💻</div>
          <div class="ct">
            <strong data-en="Desk / Office Worker" data-es="Trabajador de Oficina">Desk / Office Worker</strong>
            <span data-en="Long hours sitting — neck, back, or headaches are a daily battle" data-es="Largas horas sentado — cuello, espalda o dolores de cabeza son un problema diario">Long hours sitting — neck, back, or headaches are a daily battle</span>
          </div>
          <div class="ck">✓</div>
        </button>
      </div>
      <div class="btn-row">
        <button class="btn btn-ghost" onclick="goScreen(0)">← <span data-en="Back" data-es="Atrás">Back</span></button>
        <button class="btn btn-green" id="q1-next" onclick="goScreen(2)" disabled><span data-en="Next →" data-es="Siguiente →">Next →</span></button>
      </div>
    </div>
  </div>

  <!-- ═══ SCREEN 2: Q2 — MAIN COMPLAINT ═══ -->
  <div class="screen" id="screen-2">
    <div class="inner">
      <div class="step-num" data-en="Question 2 of 5" data-es="Pregunta 2 de 5">Question 2 of 5</div>
      <h2 data-en="What's your main issue right now?" data-es="¿Cuál es tu problema principal ahora mismo?">What's your main issue right now?</h2>
      <p class="sec-desc multi-note" data-en="Pick all that apply." data-es="Selecciona todo lo que aplique.">Pick all that apply.</p>
      <div class="choice-grid" id="q2-choices">
        <button class="choice-btn" onclick="toggleQ('q2','back')" data-val="back">
          <div class="ci">🔙</div>
          <div class="ct"><strong data-en="Back or neck pain" data-es="Dolor de espalda o cuello">Back or neck pain</strong><span data-en="Upper, mid, or lower — aching, stiff, or sharp" data-es="Superior, media o baja — dolor, rigidez o agudo">Upper, mid, or lower — aching, stiff, or sharp</span></div>
          <div class="ck">✓</div>
        </button>
        <button class="choice-btn" onclick="toggleQ('q2','joint')" data-val="joint">
          <div class="ci">🦵</div>
          <div class="ct"><strong data-en="Joint, shoulder, hip, or knee pain" data-es="Dolor de articulación, hombro, cadera o rodilla">Joint, shoulder, hip, or knee pain</strong><span data-en="Hurt with movement, after activity, or at rest" data-es="Duele con el movimiento, después de actividad, o en reposo">Hurt with movement, after activity, or at rest</span></div>
          <div class="ck">✓</div>
        </button>
        <button class="choice-btn" onclick="toggleQ('q2','nerve')" data-val="nerve">
          <div class="ci">⚡</div>
          <div class="ct"><strong data-en="Numbness, tingling, or burning" data-es="Entumecimiento, hormigueo o ardor">Numbness, tingling, or burning</strong><span data-en="Hands, feet, arms or legs feel electric, cold, or numb" data-es="Manos, pies, brazos o piernas — sensación eléctrica, fría o adormecida">Hands, feet, arms or legs feel electric, cold, or numb</span></div>
          <div class="ck">✓</div>
        </button>
        <button class="choice-btn" onclick="toggleQ('q2','chronic')" data-val="chronic">
          <div class="ci">🔄</div>
          <div class="ct"><strong data-en="Old injury or chronic pain that never fully healed" data-es="Lesión antigua o dolor crónico que nunca sanó por completo">Old injury or chronic pain that never fully healed</strong><span data-en="Tendon, plantar fascia, rotator cuff, tennis elbow, etc." data-es="Tendón, fascia plantar, manguito rotador, codo de tenista, etc.">Tendon, plantar fascia, rotator cuff, tennis elbow, etc.</span></div>
          <div class="ck">✓</div>
        </button>
        <button class="choice-btn" onclick="toggleQ('q2','headache')" data-val="headache">
          <div class="ci">🤕</div>
          <div class="ct"><strong data-en="Headaches or migraines" data-es="Dolores de cabeza o migrañas">Headaches or migraines</strong><span data-en="Frequent, tension-type, or coming from the neck" data-es="Frecuentes, tensionales o que vienen del cuello">Frequent, tension-type, or coming from the neck</span></div>
          <div class="ck">✓</div>
