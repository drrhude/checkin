      icon:'🎯',badge:'Comprehensive Care',badgeClass:'multi',
      title:'Comprehensive Care Plan',
      why:'Your answers suggest <strong>multiple things going on at once</strong> — which is actually very common. The good news: we treat all of it under one roof. A full evaluation will help us prioritize what to address first and build a clear, step-by-step plan so you\'re not overwhelmed and you see progress fast.',
      why_es:'Tus respuestas sugieren <strong>múltiples cosas sucediendo a la vez</strong> — lo cual es muy común. La buena noticia: lo tratamos todo bajo un mismo techo. Una evaluación completa nos ayudará a priorizar.'
    }
  }
};

function scoreQuiz(){
  let scores={chiro:0,sw:0,np:0,rehab:0};

  // Q1 persona (multi-select)
  if(Q.q1.includes('athlete')){scores.rehab+=3;scores.sw+=2;}
  if(Q.q1.includes('worker')){scores.chiro+=3;scores.sw+=2;}
  if(Q.q1.includes('parent')){scores.chiro+=3;}
  if(Q.q1.includes('senior')){scores.np+=2;scores.chiro+=2;}
  if(Q.q1.includes('office')){scores.chiro+=3;}

  // Q2 complaints
  if(Q.q2.includes('back'))scores.chiro+=3;
  if(Q.q2.includes('joint')&&Q.q1.includes('athlete'))scores.sw+=3;
  else if(Q.q2.includes('joint'))scores.chiro+=2;
  if(Q.q2.includes('nerve')){scores.np+=4;scores.chiro+=1;}
  if(Q.q2.includes('chronic'))scores.sw+=4;
  if(Q.q2.includes('headache'))scores.chiro+=3;
  if(Q.q2.includes('weight')){/* weight loss separate — noted in also-consider */}

  // Q3 duration
  if(Q.q3==='years'||Q.q3==='months')scores.sw+=1;

  // Q4 prior treatment
  if(Q.q4==='surgery'||Q.q4==='pt'){scores.sw+=1;scores.np+=1;}

  // Q5 goal
  if(Q.q5==='perform')scores.rehab+=2;
  if(Q.q5==='prevent')scores.chiro+=1;

  // If nerve is dominant
  if(Q.q2.includes('nerve')&&Q.q1.includes('senior'))scores.np+=2;

  return scores;
}

function getResult(){
  const scores=scoreQuiz();
  const hasWeight=Q.q2.includes('weight');
  const topScore=Math.max(...Object.values(scores));
  const topServices=Object.entries(scores).filter(([,v])=>v===topScore).map(([k])=>k);
  const primary=topServices[0];

  // Determine also-consider
  const sorted=Object.entries(scores).sort((a,b)=>b[1]-a[1]);
  const alsoConsider=sorted.slice(1,3).filter(([,v])=>v>0).map(([k])=>k);
  if(hasWeight&&!alsoConsider.includes('weight'))alsoConsider.push('weight');

  return{primary,alsoConsider,scores};
}

// ─── SUBMIT ───────────────────────────────────────
async function submitLead(){
  leadData.name=document.getElementById('lead-name').value.trim();
  leadData.phone=document.getElementById('lead-phone').value.trim();
  leadData.email=document.getElementById('lead-email').value.trim();

  const {primary,alsoConsider}=getResult();
  showResults(primary,alsoConsider);
  goScreen(6);

  // Save to sheet
  if(driveToken&&SHEET_ID){
    const statusEl=document.getElementById('sheets-status');
    if(statusEl){statusEl.innerHTML='<span class="drive-status uploading">Saving your info...</span>';}
    const row=[
      new Date().toISOString(),
      leadData.name,
      leadData.phone,
      leadData.email,
      Q.q1.join(', '),
      Q.q2.join(', '),
      Q.impact||'',
      Q.q3||'',
      Q.q4||'',
      Q.q5||'',
      primary,
      LANG,
      'vendor-event'
    ];
    const ok=await writeToSheet(row);
    if(statusEl){
      statusEl.innerHTML=ok
        ?'<span class="drive-status success">✓ Info saved</span>'
        :'<span class="drive-status error">Could not save — take their card</span>';
    }
  }
}

