function showResults(primary,alsoConsider){
  const lang=LANG;
  const R=RESULTS.en; // always use en structure, swap text by lang
  const data=R[primary]||R.chiro;

  document.getElementById('result-icon').textContent=data.icon;
  const badge=document.getElementById('result-badge');
  badge.textContent=lang==='es'?(ALSO_META.es[primary]?.name||data.badge):data.badge;
  badge.className='result-badge '+data.badgeClass;
  document.getElementById('result-title').textContent=lang==='es'?(ALSO_META.es[primary]?.name||data.title):data.title;
  document.getElementById('result-why').innerHTML=lang==='es'?data.why_es:data.why;

  // Also consider
  const meta=ALSO_META[lang]||ALSO_META.en;
  const ac=document.getElementById('also-consider');
  if(alsoConsider.length){
    const title=lang==='es'?'También podría beneficiarte:':'You may also benefit from:';
    ac.innerHTML=`<div class="also-consider-title">${title}</div><div class="mini-cards">${
      alsoConsider.map(k=>{
        const m=meta[k];
        if(!m)return'';
        return`<div class="mini-card"><div class="mi">${m.icon}</div><div class="mt"><strong>${m.name}</strong><span>${m.desc}</span></div></div>`;
      }).join('')
    }</div>`;
  } else {
    ac.innerHTML='';
  }
}

