// ─── GOOGLE AUTH ──────────────────────────────────
function gapiLoaded(){
  gapi.load('client',async()=>{
    await gapi.client.init({apiKey:'',discoveryDocs:[]});
    gapiReady=true;
    tryRestoreToken();
  });
}
function gisLoaded(){gisReady=true;if(gapiReady)tryRestoreToken();}

function tryRestoreToken(){
  const saved=localStorage.getItem('quiz_drive_token');
  const expiry=parseInt(localStorage.getItem('quiz_drive_expiry')||'0');
  const clientId=cfg.goog_id||'';
  if(!saved||!clientId)return;
  if(Date.now()<expiry){
    driveToken=saved;
    gapi.client.setToken({access_token:driveToken});
    const remaining=expiry-Date.now();
    clearTimeout(window._refreshTimer);
    window._refreshTimer=setTimeout(silentRefresh,remaining);
    setConnectedUI();
  } else if(clientId&&gisReady){
    silentRefresh();
  }
}

function silentRefresh(){
  if(!cfg.goog_id||!gisReady)return;
  const c=google.accounts.oauth2.initTokenClient({
    client_id:cfg.goog_id,scope:DRIVE_SCOPE,
    callback:(resp)=>{
      if(resp.error)return;
      driveToken=resp.access_token;
      gapi.client.setToken({access_token:driveToken});
      const expiry=Date.now()+(55*60*1000);
      localStorage.setItem('quiz_drive_token',driveToken);
      localStorage.setItem('quiz_drive_expiry',String(expiry));
      clearTimeout(window._refreshTimer);
      window._refreshTimer=setTimeout(silentRefresh,55*60*1000);
    }
  });
  c.requestAccessToken({prompt:''});
}

function initDriveAuth(){
  const clientId=document.getElementById('cfg-goog-id').value.trim()||cfg.goog_id;
  if(!clientId){alert('Enter your Google OAuth Client ID first.');return;}
  if(!gisReady){alert('Google auth still loading. Try again in a moment.');return;}
  cfg.goog_id=clientId;
  tokenClient=google.accounts.oauth2.initTokenClient({
    client_id:clientId,scope:DRIVE_SCOPE,
    callback:(resp)=>{
      if(resp.error){alert('Auth failed: '+resp.error);return;}
      driveToken=resp.access_token;
      gapi.client.setToken({access_token:driveToken});
      const expiry=Date.now()+(55*60*1000);
      localStorage.setItem('quiz_drive_token',driveToken);
      localStorage.setItem('quiz_drive_expiry',String(expiry));
      clearTimeout(window._refreshTimer);
      window._refreshTimer=setTimeout(silentRefresh,55*60*1000);
      setConnectedUI();
      ensureHeader();
    }
  });
  tokenClient.requestAccessToken({prompt:'consent'});
}

function setConnectedUI(){
  const el=document.getElementById('drive-auth-status');
  if(el)el.innerHTML='<span style="color:var(--sage-dk);font-weight:600;font-size:.84rem;">✓ Google Sheets connected</span>';
  const btn=document.getElementById('drive-connect-btn');
  if(btn){btn.textContent='✓ Connected';btn.style.background='var(--sage-dk)';btn.style.color='white';btn.disabled=true;}
}

async function ensureHeader(){
  if(!driveToken||!SHEET_ID)return;
  try{
    const r=await fetch(`${SHEETS_API}/${SHEET_ID}/values/Sheet1!A1:Z1`,{headers:{Authorization:'Bearer '+driveToken}});
    const d=await r.json();
    if(!d.values||!d.values[0]||!d.values[0].includes('name')){
      await fetch(`${SHEETS_API}/${SHEET_ID}/values/Sheet1!A1?valueInputOption=RAW`,{
        method:'PUT',headers:{'Content-Type':'application/json',Authorization:'Bearer '+driveToken},
        body:JSON.stringify({values:[SHEET_HEADERS]})
      });
    }
  }catch(e){console.warn('ensureHeader:',e);}
}

async function writeToSheet(row){
  if(!driveToken||!SHEET_ID)return false;
  await ensureHeader();
  try{
    const res=await fetch(`${SHEETS_API}/${SHEET_ID}/values/Sheet1!A1:append?valueInputOption=RAW&insertDataOption=INSERT_ROWS`,{
      method:'POST',headers:{'Content-Type':'application/json',Authorization:'Bearer '+driveToken},
      body:JSON.stringify({values:[row]})
    });
    return res.ok;
  }catch(e){console.warn('writeToSheet:',e);return false;}
}

