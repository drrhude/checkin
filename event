  const idx=Q[qkey].indexOf(val);
  if(idx===-1){Q[qkey].push(val);btn.classList.add('sel');}
  else{Q[qkey].splice(idx,1);btn.classList.remove('sel');}
  if(qkey==='q1')document.getElementById('q1-next').disabled=Q.q1.length===0;
  if(qkey==='q2')document.getElementById('q2-next').disabled=Q.q2.length===0;
}

// ─── Q3-Q5 CHIPS ─────────────────────────────────
function selectChip(qkey,el,val){
  Q[qkey]=val;
