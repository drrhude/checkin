  const dxDescriptions={
    'Tendinopathy (chronic)':'Chronic tendon degeneration — your tendon tissue has undergone changes from repeated stress that have impaired its ability to heal on its own. This is very treatable with the right approach.',
    'Enthesopathy':'Damage or degeneration where tendon or ligament attaches to bone — a common source of persistent pain that responds well to targeted therapy.',
    'Plantar Fasciitis':'Inflammation and micro-tearing of the plantar fascia — the thick band of tissue running along the bottom of your foot. Morning heel pain and pain with first steps are hallmark symptoms.',
    'Calcific Tendinitis':'Calcium deposits have formed within the tendon, causing pain and limiting movement. Shockwave therapy is highly effective at breaking down these deposits.',
    'Myofascial Pain Syndrome':'Chronic muscle and soft tissue tension with trigger points (tight knots) that refer pain to other areas. Treatment targets these points to reset tissue tone.',
    'Somatic Dysfunction':'Restricted joint motion and altered biomechanics contributing to your pain pattern. Restoring proper joint movement is a key part of your treatment.',
    'Subluxation Complex':'Vertebral joint dysfunction affecting nerve communication and movement. Chiropractic adjustments directly address this.',
    'Low Back Pain':'Pain originating from muscles, joints, or related structures of the lumbar spine. Highly responsive to the therapies recommended for you.'
  };

  // Key exam findings for ROF
  let keyFindings=[];
  S.regions.forEach(r=>{
    const cc=S.complaints[r]||{};const d=EXAM[r]||EXAM.other;
    const posTests=(S._orthoTests[r]||[]).filter((t,i)=>(S.ortho[r]||{})[i]==='pos').map(t=>t.n);
