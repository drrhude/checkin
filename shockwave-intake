async function saveAll(){
  const statusEl=document.getElementById('saveMsg');statusEl.textContent='⏳ Saving...';
  const ptFirst=document.getElementById('ptFirst').value;const ptLast=document.getElementById('ptLast').value;
  const vDate=new Date().toISOString().split('T')[0];
  const note=document.getElementById('clinNote').value;
  const fileName=`SW_Exam_${ptLast}_${ptFirst}_${vDate}.txt`;
  if(driveToken&&cfg.sheetId){
    try{
      const row=[vDate,`${ptFirst} ${ptLast}`,document.getElementById('ptDOB').value,document.getElementById('ptPhone').value,
        S.regions.map(r=>(EXAM[r]||EXAM.other).label).join(', '),getChips('dxChips').join(', '),
        document.getElementById('icdCodes').value,getChip('candChips'),getChip('sessChips'),getChip('freqChips'),
        document.getElementById('provName').value||cfg.providerName||''];
      await fetch(`https://sheets.googleapis.com/v4/spreadsheets/${cfg.sheetId}/values/Sheet1!A1:append?valueInputOption=USER_ENTERED`,
        {method:'POST',headers:{'Authorization':'Bearer '+driveToken,'Content-Type':'application/json'},body:JSON.stringify({values:[row]})});
      statusEl.textContent='✅ Logged to Sheets. ';
    }catch(e){statusEl.textContent='⚠ Sheets error. ';}
  }
  if(driveToken&&cfg.driveFolderId){
    try{
      const blob=new Blob([note],{type:'text/plain'});
      const meta=JSON.stringify({name:fileName,parents:[cfg.driveFolderId]});
      const form=new FormData();form.append('metadata',new Blob([meta],{type:'application/json'}));form.append('file',blob);
      await fetch('https://www.googleapis.com/upload/drive/v3/files?uploadType=multipart',{method:'POST',headers:{'Authorization':'Bearer '+driveToken},body:form});
      statusEl.textContent+='✅ Saved to Drive.';
    }catch(e){statusEl.textContent+=' ⚠ Drive error.';}
  }
  if(!driveToken){
    const a=document.createElement('a');a.href='data:text/plain;charset=utf-8,'+encodeURIComponent(note);a.download=fileName;a.click();
    statusEl.textContent='📥 Downloaded (connect Drive to auto-save).';
  }
}
function startNew(){if(!confirm('Start a new patient exam? All current data will be cleared.'))return;location.reload();}

// ── INIT ──
loadCfg();
const today=new Date().toISOString().split('T')[0];
document.getElementById('ptSigDate').value=today;
document.getElementById('provDate').value=today;
if(cfg.providerName)document.getElementById('provName').value=cfg.providerName;
setTimeout(()=>{initSig('ptSig');initSig('provSig');},400);
</script>
