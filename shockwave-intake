<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shockwave New Patient Exam — Colleyville Chiropractic</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<style>
:root{
  --sage-dk:#2f5c43;--sage:#5a8f6e;--sage-lt:#8ab89a;
  --cream:#f6faf7;--cream-dk:#eaf2ec;--ink:#182820;--ink-lt:#3d5445;
  --gold:#c9a84c;--teal:#2a7f7f;--amber:#c97b2a;--red:#b83232;
  --muted:#6b7f70;--border:#d4e2d8;--card:#ffffff;
  --shadow:0 2px 12px rgba(24,40,32,.08);--shadow-lg:0 8px 32px rgba(24,40,32,.14);
  --radius:12px;--radius-sm:8px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--ink);min-height:100vh;}
.topbar{position:sticky;top:0;z-index:100;background:var(--sage-dk);color:white;
  display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:56px;
  box-shadow:0 2px 8px rgba(0,0,0,.2);}
.topbar-brand{font-family:'DM Serif Display',serif;font-size:18px;letter-spacing:.02em;}
.topbar-sub{font-size:11px;opacity:.7;margin-top:1px;}
.topbar-right{display:flex;align-items:center;gap:10px;}
.settings-btn{background:rgba(255,255,255,.15);border:none;color:white;padding:6px 14px;
  border-radius:20px;font-size:13px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background .2s;}
.settings-btn:hover{background:rgba(255,255,255,.25);}
.drive-pill{font-size:12px;padding:4px 10px;border-radius:12px;font-weight:500;}
.drive-pill.on{background:rgba(42,127,127,.35);color:#a8e6e6;}
.drive-pill.off{background:rgba(201,123,42,.3);color:#f5c27a;}
.step-strip{background:var(--card);border-bottom:1px solid var(--border);padding:0 16px;display:flex;overflow-x:auto;}
.step-tab{display:flex;align-items:center;gap:7px;padding:12px 14px;font-size:12px;font-weight:500;
  color:var(--muted);border-bottom:3px solid transparent;white-space:nowrap;transition:all .2s;}
.step-tab .n{width:20px;height:20px;border-radius:50%;background:var(--border);color:var(--muted);
  display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;}
.step-tab.active{color:var(--sage-dk);border-bottom-color:var(--sage-dk);}
.step-tab.active .n{background:var(--sage-dk);color:white;}
.step-tab.done{color:var(--sage);}
.step-tab.done .n{background:var(--sage);color:white;}
.main{max-width:860px;margin:0 auto;padding:24px 16px 120px;}
.phase{display:none;animation:fi .3s ease;}
.phase.active{display:block;}
@keyframes fi{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.phase-hdr{margin-bottom:18px;}
.phase-lbl{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--sage);margin-bottom:3px;}
.phase-title{font-family:'DM Serif Display',serif;font-size:26px;color:var(--ink);}
.phase-desc{font-size:13px;color:var(--muted);margin-top:3px;}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:22px;margin-bottom:16px;box-shadow:var(--shadow);}
.card-title{font-family:'DM Serif Display',serif;font-size:16px;color:var(--sage-dk);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--cream-dk);}
.card-title .sub{font-size:12px;color:var(--muted);font-family:'DM Sans',sans-serif;font-weight:400;margin-left:8px;}
.row{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-bottom:13px;}
.row.r3{grid-template-columns:1fr 1fr 1fr;}
.row.r1{grid-template-columns:1fr;}
.field{display:flex;flex-direction:column;gap:5px;}
.field label{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;}
.field input,.field select,.field textarea{padding:10px 12px;border:1.5px solid var(--border);
  border-radius:var(--radius-sm);font-family:'DM Sans',sans-serif;font-size:14px;color:var(--ink);
  background:var(--cream);transition:border-color .2s;outline:none;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--sage);background:white;}
.field textarea{resize:vertical;min-height:74px;}
.slbl{font-size:11px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--sage);margin:16px 0 7px;}
.slbl:first-child{margin-top:0;}
.chips{display:flex;flex-wrap:wrap;gap:7px;margin-top:4px;}
.chip{padding:7px 14px;border-radius:20px;border:1.5px solid var(--border);font-size:13px;font-weight:500;
  cursor:pointer;transition:all .15s;background:var(--cream);color:var(--ink-lt);user-select:none;}
.chip:hover{border-color:var(--sage-lt);}
.chip.sel{background:var(--sage-dk);color:white;border-color:var(--sage-dk);}
.chip.sel-amber{background:var(--amber);color:white;border-color:var(--amber);}
.chip.sel-teal{background:var(--teal);color:white;border-color:var(--teal);}
.pain-scale{display:flex;gap:5px;flex-wrap:wrap;}
.pb{width:38px;height:38px;border-radius:8px;border:1.5px solid var(--border);font-size:14px;font-weight:700;
  cursor:pointer;font-family:'DM Sans',sans-serif;background:white;color:var(--ink);transition:all .15s;}
.pb.on{color:white;border-color:transparent;}
.pb[data-n="0"].on,.pb[data-n="1"].on,.pb[data-n="2"].on{background:var(--teal);}
.pb[data-n="3"].on,.pb[data-n="4"].on,.pb[data-n="5"].on{background:#e0a020;}
.pb[data-n="6"].on,.pb[data-n="7"].on{background:var(--amber);}
.pb[data-n="8"].on,.pb[data-n="9"].on,.pb[data-n="10"].on{background:var(--red);}
.check-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.ci{display:flex;align-items:center;gap:8px;padding:9px 12px;border-radius:var(--radius-sm);
  border:1.5px solid var(--border);background:var(--cream);font-size:13px;cursor:pointer;transition:all .15s;}
.ci input[type="checkbox"]{width:15px;height:15px;accent-color:var(--sage-dk);cursor:pointer;flex-shrink:0;}
.ci.checked{background:#eef7f0;border-color:var(--sage);}
.contra-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.contra-item{display:flex;align-items:flex-start;gap:9px;padding:10px 12px;border-radius:var(--radius-sm);
  border:1.5px solid var(--border);background:var(--cream);font-size:13px;cursor:pointer;transition:all .15s;}
.contra-item input[type="checkbox"]{width:15px;height:15px;accent-color:var(--sage-dk);flex-shrink:0;margin-top:2px;cursor:pointer;}
.contra-item.abs-hit{background:#fdf0f0;border-color:var(--red);color:var(--red);}
.contra-item.rel-hit{background:#fdf8ec;border-color:var(--amber);}
.ctag{font-size:10px;font-weight:700;text-transform:uppercase;padding:2px 7px;border-radius:10px;flex-shrink:0;margin-left:auto;}
.ctag.abs{background:#fbe0e0;color:var(--red);}
.ctag.rel{background:#fdf0d8;color:var(--amber);}
.alert{padding:13px 16px;border-radius:var(--radius-sm);font-size:14px;font-weight:500;
  display:none;margin-bottom:14px;align-items:flex-start;gap:9px;}
.alert.show,.alert.visible{display:flex;}
.alert.danger{background:#fdf0f0;border:1.5px solid var(--red);color:var(--red);}
.alert.warning{background:#fdf8ec;border:1.5px solid var(--amber);color:#8a5a10;}
.alert.success{background:#eef7f0;border:1.5px solid var(--sage);color:var(--sage-dk);}
.alert.info{background:#e8f4f8;border:1.5px solid #5a9fbf;color:#1a5f7a;}
.otest{display:flex;align-items:center;justify-content:space-between;padding:10px 13px;
  border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--cream);margin-bottom:7px;}
.otest-name{font-size:13px;font-weight:600;}
.otest-desc{font-size:11px;color:var(--muted);margin-top:2px;}
.otest-btns{display:flex;gap:6px;flex-shrink:0;}
.obtn{padding:5px 13px;border-radius:14px;border:1.5px solid var(--border);font-size:12px;font-weight:600;
  cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .15s;background:white;}
.obtn.neg{color:var(--teal);}
.obtn.pos{color:var(--red);}
.obtn.on-neg{background:var(--teal);color:white;border-color:var(--teal);}
.obtn.on-pos{background:var(--red);color:white;border-color:var(--red);}
.rom-grid{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px;}
.rom-f{display:flex;flex-direction:column;gap:4px;}
.rom-f label{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;}
.rom-f input{padding:8px 10px;border:1.5px solid var(--border);border-radius:var(--radius-sm);
  font-family:'DM Sans',sans-serif;font-size:14px;color:var(--ink);background:var(--cream);width:100%;outline:none;}
.rom-f input:focus{border-color:var(--sage);background:white;}
.rom-sub{font-size:10px;color:var(--muted);margin-top:1px;}
.palp-box{border:1.5px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;margin-bottom:8px;}
.palp-hdr{padding:9px 13px;background:var(--cream-dk);font-size:12px;font-weight:600;color:var(--ink-lt);}
.palp-body{padding:11px 13px;display:flex;flex-wrap:wrap;gap:6px;}
.proto-box{background:var(--ink);color:white;border-radius:var(--radius);padding:22px;margin-bottom:16px;}
.proto-title{font-family:'DM Serif Display',serif;font-size:20px;margin-bottom:16px;color:#a8d8b0;}
.proto-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:16px;}
.proto-stat{background:rgba(255,255,255,.08);border-radius:8px;padding:12px 14px;}
.proto-stat-val{font-size:22px;font-weight:700;color:white;font-family:'DM Serif Display',serif;}
.proto-stat-lbl{font-size:11px;color:rgba(255,255,255,.55);text-transform:uppercase;letter-spacing:.06em;margin-top:2px;}
.proto-note{font-size:13px;color:rgba(255,255,255,.75);line-height:1.6;margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.12);}
.proto-note strong{color:white;}
.sig-wrap{border:1.5px solid var(--border);border-radius:var(--radius-sm);background:white;overflow:hidden;}
.sig-label-bar{padding:8px 13px;background:var(--cream-dk);font-size:11px;font-weight:600;color:var(--muted);
  text-transform:uppercase;letter-spacing:.05em;display:flex;align-items:center;justify-content:space-between;}
.sig-canvas{display:block;width:100%;height:140px;cursor:crosshair;touch-action:none;}
.sig-clear{background:none;border:none;font-size:12px;color:var(--muted);cursor:pointer;font-family:'DM Sans',sans-serif;text-decoration:underline;}
.consent-text{font-size:12px;color:var(--muted);line-height:1.65;padding:14px;background:var(--cream);
  border-radius:var(--radius-sm);border:1px solid var(--border);margin-bottom:12px;}
.consent-text strong{color:var(--ink);}
.handoff{display:none;position:fixed;inset:0;z-index:200;background:var(--sage-dk);
  align-items:center;justify-content:center;flex-direction:column;text-align:center;padding:40px;}
.handoff.show{display:flex;}
.handoff-icon{font-size:72px;margin-bottom:20px;}
.handoff-title{font-family:'DM Serif Display',serif;font-size:34px;color:white;margin-bottom:10px;}
.handoff-sub{font-size:15px;color:rgba(255,255,255,.7);margin-bottom:36px;max-width:400px;line-height:1.6;}
.pin-row{display:flex;gap:10px;justify-content:center;margin-bottom:16px;}
.pin-box{width:56px;height:64px;border-radius:10px;border:2px solid rgba(255,255,255,.35);
  background:rgba(255,255,255,.1);color:white;font-size:28px;text-align:center;font-family:'DM Sans',sans-serif;outline:none;}
.pin-box:focus{border-color:white;}
.pin-err{color:#f5a0a0;font-size:13px;min-height:18px;}
.modal-ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:300;align-items:center;justify-content:center;}
.modal-ov.show{display:flex;}
.modal{background:white;border-radius:var(--radius);padding:28px;width:90%;max-width:500px;max-height:85vh;overflow-y:auto;box-shadow:var(--shadow-lg);}
.modal-title{font-family:'DM Serif Display',serif;font-size:22px;margin-bottom:18px;}
.modal-footer{display:flex;gap:10px;margin-top:18px;justify-content:flex-end;}
.btn{padding:11px 26px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:600;cursor:pointer;border:none;transition:all .2s;display:inline-flex;align-items:center;gap:8px;}
.btn-p{background:var(--sage-dk);color:white;}
.btn-p:hover{background:var(--ink);}
.btn-p:disabled{background:var(--border);color:var(--muted);cursor:not-allowed;}
.btn-o{background:transparent;color:var(--sage-dk);border:1.5px solid var(--sage-dk);}
.btn-o:hover{background:var(--cream-dk);}
.btn-gold{background:var(--gold);color:white;}
.btn-gold:hover{background:#b8942a;}
.btn-sm{padding:8px 16px;font-size:13px;}
.btn-row{display:flex;gap:12px;align-items:center;margin-top:22px;flex-wrap:wrap;}
.sum-row{display:flex;gap:12px;padding:7px 0;border-bottom:1px solid var(--cream-dk);font-size:13px;}
.sum-row:last-child{border-bottom:none;}
.sum-k{font-weight:600;min-width:160px;color:var(--muted);flex-shrink:0;}
.sum-v{color:var(--ink);}
.badge{display:inline-flex;align-items:center;padding:2px 9px;border-radius:10px;font-size:11px;font-weight:600;}
.badge-red{background:#fdf0f0;color:var(--red);}
.badge-amber{background:#fdf8ec;color:var(--amber);}
.badge-green{background:#eef7f0;color:var(--sage-dk);}
.lang-toggle{display:flex;border:1.5px solid var(--border);border-radius:8px;overflow:hidden;}
.lang-btn{padding:6px 16px;font-size:13px;font-weight:600;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--muted);transition:all .15s;}
.lang-btn.active{background:var(--sage-dk);color:white;}
.note-ta{width:100%;min-height:260px;font-family:'DM Sans',sans-serif;font-size:13px;padding:14px;
  border:1.5px solid var(--border);border-radius:8px;background:var(--cream);color:var(--ink);outline:none;resize:vertical;line-height:1.6;}
.note-ta:focus{border-color:var(--sage);background:white;}
/* COMPLAINT CARDS */
.complaint-card{border:1.5px solid var(--sage-lt);border-radius:var(--radius);padding:18px;margin-bottom:12px;background:linear-gradient(to bottom,rgba(90,143,110,.04),white);}
.complaint-card-title{font-family:'DM Serif Display',serif;font-size:15px;color:var(--sage-dk);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.complaint-card-title .region-badge{background:var(--sage-dk);color:white;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:600;padding:3px 10px;border-radius:12px;}
/* SERVICE CARD */
.svc-card{border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin-bottom:8px;background:var(--cream);}
.svc-card.active-svc{border-color:var(--sage);background:#f0f8f2;}
.svc-toggle{display:flex;align-items:center;gap:10px;cursor:pointer;font-weight:600;font-size:14px;}
.svc-toggle input[type="checkbox"]{width:16px;height:16px;accent-color:var(--sage-dk);cursor:pointer;flex-shrink:0;}
.svc-detail{margin-top:12px;padding-top:12px;border-top:1px solid var(--border);}
/* ROF STYLES */
.rof-page{background:white;max-width:780px;margin:0 auto;padding:48px;border-radius:var(--radius);box-shadow:var(--shadow-lg);}
.rof-header{border-bottom:3px solid var(--sage-dk);padding-bottom:20px;margin-bottom:28px;}
.rof-clinic{font-family:'DM Serif Display',serif;font-size:26px;color:var(--sage-dk);}
.rof-sub{font-size:13px;color:var(--muted);margin-top:2px;}
.rof-doc-title{font-family:'DM Serif Display',serif;font-size:20px;color:var(--ink);margin-top:16px;}
.rof-section{margin-bottom:24px;}
.rof-section-title{font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--sage);
  border-bottom:1px solid var(--cream-dk);padding-bottom:6px;margin-bottom:12px;}
.rof-dx-box{background:var(--sage-dk);color:white;border-radius:var(--radius-sm);padding:16px 20px;margin-bottom:12px;}
.rof-dx-name{font-family:'DM Serif Display',serif;font-size:18px;margin-bottom:4px;}
.rof-dx-plain{font-size:13px;opacity:.85;line-height:1.6;}
.rof-finding{display:flex;gap:10px;padding:8px 0;border-bottom:1px solid var(--cream-dk);font-size:13px;}
.rof-finding:last-child{border-bottom:none;}
.rof-finding-lbl{font-weight:600;min-width:140px;color:var(--muted);flex-shrink:0;}
.rof-plan-row{display:flex;gap:8px;align-items:flex-start;padding:7px 0;font-size:13px;}
.rof-plan-icon{font-size:16px;flex-shrink:0;margin-top:1px;}
.rof-sig-row{display:flex;gap:40px;margin-top:32px;padding-top:20px;border-top:2px solid var(--cream-dk);}
.rof-sig-block{flex:1;}
.rof-sig-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:8px;}
.rof-sig-line{border-bottom:1.5px solid var(--ink);height:50px;margin-bottom:4px;}
.rof-sig-name{font-size:12px;color:var(--muted);}
.divider{border:none;border-top:1px solid var(--cream-dk);margin:16px 0;}
@media print{
  .topbar,.step-strip,.btn-row,.btn,.settings-btn,.handoff,.modal-ov,.lang-toggle{display:none!important;}
  .phase{display:block!important;}
  body{background:white;}
  .card{box-shadow:none;border:1px solid #ccc;break-inside:avoid;}
  .rof-page{box-shadow:none;padding:20px;}
}
@media(max-width:600px){
  .row,.row.r3{grid-template-columns:1fr;}
  .contra-grid,.check-grid{grid-template-columns:1fr;}
  .rom-grid{grid-template-columns:1fr 1fr;}
  .proto-grid{grid-template-columns:1fr 1fr;}
}
</style>
</head>
<body>
<div class="topbar">
  <div><div class="topbar-brand">Colleyville Chiropractic</div><div class="topbar-sub">Shockwave New Patient Examination</div></div>
  <div class="topbar-right">
    <div class="drive-pill off" id="drivePill">Drive ○</div>
    <button class="settings-btn" onclick="openSettings()">⚙ Settings</button>
  </div>
</div>
<div class="step-strip">
  <div class="step-tab active" id="tab0"><span class="n">1</span>Demographics</div>
  <div class="step-tab" id="tab1"><span class="n">2</span>History</div>
  <div class="step-tab" id="tab2"><span class="n">3</span>Consent</div>
  <div class="step-tab" id="tab3"><span class="n">4</span>Candidacy</div>
  <div class="step-tab" id="tab4"><span class="n">5</span>Exam</div>
  <div class="step-tab" id="tab5"><span class="n">6</span>Protocol</div>
  <div class="step-tab" id="tab6"><span class="n">7</span>Treatment</div>
  <div class="step-tab" id="tab7"><span class="n">8</span>Summary</div>
  <div class="step-tab" id="tab8"><span class="n">★</span>ROF</div>
</div>
<div class="main">
<!-- ═══ PHASE 0: DEMOGRAPHICS ═══ -->
<div class="phase active" id="phase0">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px;margin-bottom:18px;">
    <div class="phase-hdr" style="margin:0;"><div class="phase-lbl">Patient Self-Service — Page 1 of 2</div><div class="phase-title">Personal Information</div><div class="phase-desc">Please complete all fields. Your information is kept strictly confidential.</div></div>
    <div class="lang-toggle"><button class="lang-btn active" id="lbEn" onclick="setLang('en')">EN</button><button class="lang-btn" id="lbEs" onclick="setLang('es')">ES</button></div>
  </div>
  <div class="card">
    <div class="card-title" data-en="Patient Information" data-es="Información del Paciente">Patient Information</div>
    <div class="row r3">
      <div class="field"><label data-en="First Name" data-es="Nombre">First Name</label><input id="ptFirst" placeholder="First name"></div>
      <div class="field"><label data-en="Last Name" data-es="Apellido">Last Name</label><input id="ptLast" placeholder="Last name"></div>
      <div class="field"><label data-en="Date of Birth" data-es="Fecha de Nacimiento">Date of Birth</label><input id="ptDOB" type="date"></div>
    </div>
    <div class="row">
      <div class="field"><label data-en="Phone Number" data-es="Teléfono">Phone Number</label><input id="ptPhone" placeholder="(817) 000-0000"></div>
      <div class="field"><label data-en="Email Address" data-es="Correo Electrónico">Email Address</label><input id="ptEmail" type="email" placeholder="email@example.com"></div>
    </div>
    <div class="row r1"><div class="field"><label data-en="Home Address" data-es="Dirección">Home Address</label><input id="ptAddr" placeholder="Street, City, State, ZIP"></div></div>
    <div class="row">
      <div class="field"><label data-en="Preferred Language" data-es="Idioma Preferido">Preferred Language</label>
